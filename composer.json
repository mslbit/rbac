{
    "name": "maiscraft/rbac",
    "description": "Framework-agnostic RBAC + Auth engine. Guard/UserProvider strategy pattern, AuthManager, Casbin RBAC, zero framework dependency.",
    "type": "library",
    "license": "MIT",

    "authors": [
        {
            "name": "MaisCraft Team",
            "email": "team@mslbit.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "casbin/casbin": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Maiscraft\\Rbac\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maiscraft\\Rbac\\Tests\\": "tests/"
        }
    },
    "keywords": [
        "rbac",
        "casbin",
        "auth",
        "guard",
        "acl",
        "permission",
        "psr-11",
        "php8"
    ],
    "homepage": "https://github.com/mslbit/rbac",
    "support": {
        "issues": "https://github.com/mslbit/rbac/issues",
        "source": "https://github.com/mslbit/rbac"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
